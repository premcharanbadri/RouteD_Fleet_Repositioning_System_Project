# Database — defaults to a local SQLite file. For PostgreSQL use e.g.:
# DATABASE_URL=postgresql+psycopg://routeiq:routeiq@localhost:5432/routeiq
DATABASE_URL=sqlite:///./routeiq.db

# AI — optional. Without a key, RouteIQ falls back to a deterministic rule-based
# parser/briefing so the app still runs fully offline.
ANTHROPIC_API_KEY=
ROUTEIQ_AI_MODEL=claude-opus-4-7

# CORS origin for the frontend dev server
FRONTEND_ORIGIN=http://localhost:5173

# Snowflake analytics warehouse (OLAP tier) — optional. Set all five core vars to
# enable /api/analytics/*; without them those endpoints return 503. The
# operational app (orders, optimize, planning) never depends on Snowflake.
# Requires the optional extra:  pip install -e ".[snowflake]"
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=
